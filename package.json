{
  "name": "shlesha-wasm",
  "version": "0.1.0",
  "description": "High-performance lossless transliteration library for JavaScript/WebAssembly",
  "main": "pkg/shlesha.js",
  "types": "pkg/shlesha.d.ts",
  "files": [
    "pkg/*"
  ],
  "scripts": {
    "build": "wasm-pack build --target web --release",
    "build-nodejs": "wasm-pack build --target nodejs --release",
    "build-bundler": "wasm-pack build --target bundler --release",
    "test": "wasm-pack test --headless --firefox",
    "test-node": "wasm-pack test --node"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/udapaana/shlesha.git"
  },
  "keywords": [
    "transliteration",
    "indic",
    "sanskrit",
    "devanagari",
    "lossless",
    "wasm",
    "webassembly"
  ],
  "author": "Shlesha Contributors",
  "license": "MIT OR Apache-2.0",
  "bugs": {
    "url": "https://github.com/udapaana/shlesha/issues"
  },
  "homepage": "https://github.com/udapaana/shlesha#readme",
  "devDependencies": {
    "wasm-pack": "^0.12.0"
  },
  "dependencies": {},
  "engines": {
    "node": ">=14"
  }
}